---
import Button from "../components/button.astro";
import Projects from "../components/home/projects.astro";
import Separator from "../components/home/separator.astro";
import Writings from "../components/home/writings.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="Jakub Siekiera - Intro">
  <div class="relative z-20 w-full max-w-5xl mx-auto mt-16 px-7 md:mt-24 lg:mt-32 xl:px-0">
    <div class="flex flex-col items-center md:flex-row">
      <div class="relative w-full md:w-1/2 md:pr-8">
        <h1 class="mb-5 text-5xl font-extrabold leading-tight md:text-6xl lg:text-7xl dark:text-white animate-glitch">
          <span class="glitch-text" data-text="swe, CS,">swe, CS,</span><br/>
          <span class="glitch-text" data-text="founder @ cupidai">founder @ cupidai</span>
        </h1>
        <p class="mb-6 text-lg text-neutral-600 dark:text-neutral-400 font-medium">
          Working around the clock to deploy next generation software.
        </p>
        <div class="mb-6 p-6 bg-gradient-to-r from-indigo-100 to-purple-200 dark:from-indigo-900 dark:to-purple-800 rounded-xl shadow-2xl animate-pulse-glow">
          <p class="font-bold text-xl text-indigo-800 dark:text-indigo-200 mb-4">I'm pretty good at:</p>
          <ul class="grid grid-cols-2 gap-4 text-sm text-indigo-700 dark:text-indigo-300">
            <li class="animate-float-sparkle" style="animation-delay: 0s;">
              <span class="text-lg mr-2">🔮</span>Next.js/TRPc
            </li>
            <li class="animate-float-sparkle" style="animation-delay: 0.2s;">
              <span class="text-lg mr-2">⚛️</span>Golang
            </li>
            <li class="animate-float-sparkle" style="animation-delay: 0.4s;">
              <span class="text-lg mr-2">🚀</span>Python
            </li>
            <li class="animate-float-sparkle" style="animation-delay: 0.6s;">
              <span class="text-lg mr-2">🎨</span>Fastapi
            </li>
            <li class="animate-float-sparkle" style="animation-delay: 0.8s;">
              <span class="text-lg mr-2">🧙‍♂️</span>Docker
            </li>
            <li class="animate-float-sparkle" style="animation-delay: 1s;">
              <span class="text-lg mr-2">🔥</span>C++
            </li>
          </ul>
        </div>
        <Button text="Reach me on X" link="https://twitter.com/jcob_sikorski" class="animate-bounce-rotate" />
      </div>
      <div class="relative w-full mt-10 md:w-1/2 md:mt-0">
        <div class="relative z-30 animate-levitate">
          <img
            src="https://ucarecdn.com/e906be7c-3279-4095-a7d3-7b0d92d922b5/-/preview/662x1000/"
            loading="eager"
            decoding="auto"
            class="relative z-30 w-full max-w-md mx-auto rounded-full shadow-2xl border-4 border-purple-500 hover:scale-105 transition-transform duration-300"
            alt="Profile Photo"
          />
        </div>
        <div class="absolute top-0 right-0 -z-10 w-full h-full bg-gradient-to-br from-blue-400 via-purple-500 to-pink-500 opacity-20 blur-3xl animate-morph"></div>
      </div>
    </div>
  </div>
  <div class="relative z-20 w-full max-w-5xl mx-auto mt-16 px-7 md:mt-24 lg:mt-32 xl:px-0">
    <video 
      class="w-full rounded-xl shadow-2xl animate-levitate"
      controls
      autoplay
      loop
      muted
    >
      <source src="https://ucarecdn.com/e8505e20-b9ea-456c-b4e4-f548aa71bfb2/MOVtoMP4video1.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
  </div>
  <div class="w-full max-w-5xl mx-auto mt-16 px-7 xl:px-0">
    <img 
      src="https://ucarecdn.com/060b61b9-3623-4277-8d1c-c6e8e4ebcdea/Screenshot20240801at35115PM.png" 
      alt="Contributions" 
      class="w-full rounded-lg shadow-lg animate-float-contributions"
    />
  </div>
  <Separator text="Projects" />
  <Projects />
  <Separator text="Writings" />
  <Writings />
</Layout>

<style>
  @keyframes glitch {
    0% { transform: translate(0) }
    20% { transform: translate(-2px, 2px) }
    40% { transform: translate(-2px, -2px) }
    60% { transform: translate(2px, 2px) }
    80% { transform: translate(2px, -2px) }
    100% { transform: translate(0) }
  }
  .animate-glitch {
    animation: glitch 1s infinite;
  }
  .glitch-text {
    position: relative;
    display: inline-block;
  }
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .glitch-text::before {
    left: 2px;
    text-shadow: -2px 0 #ff00c1;
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim 5s infinite linear alternate-reverse;
  }
  .glitch-text::after {
    left: -2px;
    text-shadow: -2px 0 #00fff9, 2px 2px #ff00c1;
    clip: rect(44px, 450px, 56px, 0);
    animation: glitch-anim2 5s infinite linear alternate-reverse;
  }

  @keyframes stargazing {
    0%, 100% { box-shadow: 0 0 5px rgba(255, 255, 255, 0.8), 0 0 10px rgba(255, 255, 255, 0.5), 0 0 15px rgba(255, 255, 255, 0.3); }
    50% { box-shadow: 0 0 10px rgba(255, 255, 255, 0.8), 0 0 20px rgba(255, 255, 255, 0.5), 0 0 30px rgba(255, 255, 255, 0.3); }
  }
  .animate-stargazing {
    animation: stargazing 4s ease-in-out infinite;
  }

  @keyframes float {
    0% { transform: translateY(0px) }
    50% { transform: translateY(-5px) }
    100% { transform: translateY(0px) }
  }
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  @keyframes bounce-rotate {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(5deg); }
  }
  .animate-bounce-rotate {
    animation: bounce-rotate 2s infinite;
  }

  @keyframes levitate {
    0% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(2deg); }
    100% { transform: translateY(0) rotate(0deg); }
  }
  .animate-levitate {
    animation: levitate 6s ease-in-out infinite;
  }

  @keyframes morph {
    0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
  }
  .animate-morph {
    animation: morph 8s ease-in-out infinite;
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(129, 140, 248, 0.5); }
    50% { box-shadow: 0 0 40px rgba(167, 139, 250, 0.8); }
  }

  .animate-pulse-glow {
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes float-sparkle {
    0%, 100% { 
      transform: translateY(0);
      text-shadow: 0 0 0 rgba(255, 255, 255, 0);
    }
    50% { 
      transform: translateY(-10px);
      text-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
    }
  }

  .animate-float-sparkle {
    animation: float-sparkle 3s ease-in-out infinite;
    transition: all 0.3s ease;
  }

  .animate-float-sparkle:hover {
    transform: scale(1.1);
    text-shadow: 0 0 15px rgba(255, 255, 255, 1);
  }

  @keyframes float-contributions {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .animate-float-contributions {
    animation: float-contributions 6s ease-in-out infinite;
  }
</style>