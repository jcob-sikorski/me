---
import experiences from "../collections/experiences.json";
import AboutExperience from "../components/about-experience.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="About Me">
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="About Me"
      description="Hi there! 👋 I'm a software engineer from Warsaw, Poland. I love creating new products and exploring new technology."
    />

    <img src="https://ucarecdn.com/798b6c23-e182-4d72-bcb4-44e93d99cf6b/-/preview/1000x667/" class="relative z-30 w-full my-10 rounded-xl" />

    <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">Bio</h2>
    <p class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg">
      <strong>Lead Software Engineer / Co-founder @ CupidAI</strong><br>
      At CupidAI, I architect and develop the backend infrastructure for a premium deepfake generation service. My role involves designing scalable systems, ensuring high performance, and maintaining the overall reliability of our platform.
      <br><br>
      <strong>Software Engineer @ LiVE</strong><br>
      At LiVE, I played a crucial role in developing a location-based, real-time messaging app. My responsibilities included implementing Telegram-like chat features, enabling full-text search across location databases, tracking user actions within the app, and integrating both Apple and Google Maps with advanced clustering techniques for an enhanced user experience.
    </p>    

    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experience
    </h2>
    <div class="px-5 py-10">
      {
        experiences.map((experience, loop) => {
          return (
            <>
              {loop == 0 || loop == 1 ? (
                <div class="pb-10 border-l border-gray-200 dark:border-neutral-700">
                  <AboutExperience
                    dates={experience.dates}
                    role={experience.role}
                    company={experience.company}
                    description={experience.description}
                    logo={experience.logo}
                  />
                </div>
              ) : (
                <AboutExperience
                  dates={experience.dates}
                  role={experience.role}
                  company={experience.company}
                  description={experience.description}
                  logo={experience.logo}
                />
              )}
            </>
          )
        })
      }
    </div>

    <h2 class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200">Let's Connect</h2>
    <p
      class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
    >
      If you want to stay up to date with my work be sure to <a
        href="https://twitter.com/ccikai"
        target="_blank"
        class="text-indigo-600 underline">follow me on X</a
      >, or you can send me an <a href="mailto:jm.siekiera@gmail.com" class="text-indigo-600 underline"
        >email</a
      > and I'll be sure to get back to you.
    </p>
  </section>
</Layout>
