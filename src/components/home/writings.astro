---
import Button from "../button.astro";
import PostsLoop from "../posts-loop.astro";
---

<section class="max-w-5xl mx-auto px-7 lg:px-0 mt-16 md:mt-24 lg:mt-32">
  <div class="flex flex-col md:flex-row items-start justify-between">
    <div class="md:w-1/2 pr-8">
      <h2
        class="text-4xl md:text-5xl font-extrabold leading-tight tracking-tight text-neutral-900 dark:text-white mb-4 animate-glitch"
      >
        <span class="glitch-text" data-text="Arcane Scrolls">Writings</span>
      </h2>
      <p class="mb-8 text-lg text-neutral-600 dark:text-neutral-400 font-medium animate-float">
        Here I'm writing about stuff that I'm currently working on.
      </p>

      <div class="w-full mx-auto my-10 xl:px-0">
        <div class="space-y-10">
          <PostsLoop count="3" />
          
          <div class="flex items-center justify-center w-full py-5">
            <Button text="Unveil All Writings" link="/posts" class="animate-bounce-rotate" />
          </div>
        </div>
      </div>
    </div>
    
    <div class="md:w-1/2 mt-8 md:mt-0">
      <img 
        src="https://ucarecdn.com/4d3400e0-e1f7-4bc2-a42c-86648847ffe0/-/preview/1000x750/" 
        alt="Arcane Scrolls Image" 
        class="w-full h-auto rounded-lg shadow-lg animate-pulse-glow"
      />
    </div>
  </div>
</section>

<style>
  /* Include the styles from the previous examples here */
  
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(129, 140, 248, 0.5); }
    50% { box-shadow: 0 0 40px rgba(167, 139, 250, 0.8); }
  }

  .animate-pulse-glow {
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes spin-slow {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .animate-spin-slow {
    animation: spin-slow 10s linear infinite;
  }

  /* Add any additional styles from the previous examples that you want to use */
</style>